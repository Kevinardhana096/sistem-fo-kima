# Production Database Configuration
# Copy this file to .env.production and fill in your actual credentials
# NEVER commit .env.production to git!

# Production Database URL
# Format: postgresql://username:password@host:port/database?sslmode=require
DATABASE_URL="postgresql://username:password@host:port/database?sslmode=require"

# Example for different providers:
# Supabase: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# Railway: postgresql://postgres:[PASSWORD]@[HOST].railway.app:5432/railway
# Neon: postgresql://[USER]:[PASSWORD]@[HOST].neon.tech/[DATABASE]?sslmode=require
# Heroku: postgres://[USER]:[PASSWORD]@[HOST].compute.amazonaws.com:5432/[DATABASE]

# Usage:
# export $(cat .env.production | xargs) && npm run prisma:seed:cendikia
