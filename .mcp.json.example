{
  "_comment": "Template MCP config. Copy to .mcp.json and fill in secrets locally. NEVER commit real keys (.mcp.json is gitignored). Rotate any key that has ever been committed.",
  "mcpServers": {
    "serena": {
      "type": "stdio",
      "command": "serena",
      "args": [
        "start-mcp-server",
        "--project-from-cwd"
      ],
      "env": {}
    },
    "supabase": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "supabase-mcp-claude"
      ],
      "env": {
        "SUPABASE_URL": "https://<project-ref>.supabase.co",
        "SUPABASE_ANON_KEY": "<set-locally-do-not-commit>",
        "SUPABASE_SERVICE_ROLE_KEY": "<set-locally-do-not-commit>",
        "MCP_API_KEY": "<set-locally-do-not-commit>"
      }
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--browser=chrome"
      ],
      "env": {
        "PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD": "1"
      }
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "depwire": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "depwire-cli",
        "mcp"
      ]
    }
  }
}
