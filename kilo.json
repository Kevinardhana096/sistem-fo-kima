{
  "$schema": "https://app.kilo.ai/config.json",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["node","node_modules/@playwright/mcp/cli.js","--browser","chrome","--executable-path","/usr/bin/google-chrome"],
      "enabled": true,
      "timeout": 30000
    },
    "supabase": {
      "type": "local",
      "command": ["node","node_modules/supabase-mcp/dist/esm/claude-entry.js"],
      "enabled": true,
      "timeout": 30000
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["npx","-y","@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true,
      "timeout": 30000
    },
    "depwire": {
      "type": "local",
      "command": ["npx","-y","depwire-cli","mcp"],
      "enabled": true,
      "timeout": 30000
    }
  }
}
