# Frontend environment template — Sistem FO KIMA
#
# Copy this file to one of:
#   frontend/.env.development   (untuk `npm run dev`)
#   frontend/.env.production    (untuk build production)
# lalu isi nilainya. JANGAN commit file .env yang berisi nilai asli.
#
# CATATAN KEAMANAN:
# - Gunakan Supabase project TERPISAH untuk development dan production.
# - Jangan pernah memakai kredensial production untuk pengembangan lokal.

# --- Supabase (wajib) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Opsional ---
# Nama bucket Supabase Storage untuk dokumen (bila berbeda dari default).
VITE_SUPABASE_STORAGE_BUCKET=
# Host layanan Valhalla untuk fitur route planner FO.
# Contoh lokal: http://localhost:8002
VITE_VALHALLA_HOST=
# Nomor WhatsApp admin untuk tautan bantuan akses di halaman login.
VITE_ADMIN_WHATSAPP_NUMBER=
# Base URL API tambahan (dipakai pada sebagian konfigurasi production).
VITE_API_BASE_URL=

# --- Quick login khusus DEVELOPMENT (opsional) ---
# Tombol "Quick login" di halaman login hanya muncul pada build development
# DAN hanya untuk akun yang email + password-nya diisi di bawah ini.
# Isi HANYA di frontend/.env.development lokal (tidak di-commit), dan arahkan
# ke akun pada Supabase project DEV — bukan akun production.
VITE_DEV_ADMIN_EMAIL=
VITE_DEV_ADMIN_PASSWORD=
VITE_DEV_TEKNISI_EMAIL=
VITE_DEV_TEKNISI_PASSWORD=
VITE_DEV_ISP_EMAIL=
VITE_DEV_ISP_PASSWORD=
